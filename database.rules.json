{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "couples": {
      "$coupleId": {
        ".read":  "auth != null && (data.child('members').child(auth.uid).exists())",
        ".write": "auth != null && (data.child('members').child(auth.uid).exists() || !data.exists())"
      }
    },
    "activities": {
      "$coupleId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "$uid === auth.uid"
        }
      }
    },
    "messages": {
      "$coupleId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "$msgId": {
          ".validate": "newData.child('text').isString() && newData.child('text').val().length <= 150"
        }
      }
    },
    "goals": {
      "$coupleId": {
        ".read":  "auth != null",
        "$uid": {
          ".write": "$uid === auth.uid"
        }
      }
    },
    "achievements": {
      "$coupleId": {
        ".read":  "auth != null",
        "$uid": {
          ".write": "$uid === auth.uid"
        }
      }
    }
  }
}
